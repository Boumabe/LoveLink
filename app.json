{
  "expo": {
    "name": "LoveLink",
    "slug": "lovelink",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "platforms": ["ios", "android", "web"],
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.boumabe.lovelink"
    },
    "android": {
      "package": "com.boumabe.lovelink"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "extra": {
      "eas": {
        "projectId": "8f4e443d-1d46-4f3f-935d-257fcbc14c1d"
      }
    }
  }
}
